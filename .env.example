# PostgreSQL connection string
DATABASE_URL=postgres://user:pass@postgres:5432/memory?sslmode=require

# Static OAuth credentials (dapat dihasilkan dengan openssl rand -hex 32)
OAUTH_CLIENT_ID=my-client-id
OAUTH_CLIENT_SECRET=my-client-secret

# JWT signing secret (default fallback: MEMORY_API_TOKEN)
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32

# Public URL of this server (untuk OAuth issuer metadata), tanpa trailing slash
PUBLIC_URL=https://memory.example.com

# HTTP listen port
PORT=3000
