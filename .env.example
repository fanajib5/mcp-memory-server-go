# PostgreSQL connection string
DATABASE_URL=postgres://user:pass@postgres:5432/memory?sslmode=require

# Static OAuth credentials (dapat dihasilkan dengan openssl rand -hex 32)
OAUTH_CLIENT_ID=my-client-id
OAUTH_CLIENT_SECRET=my-client-secret

# JWT signing secret (default fallback: MEMORY_API_TOKEN)
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32

# Public URL of this server (untuk OAuth issuer metadata), tanpa trailing slash
PUBLIC_URL=https://memory.example.com

# CORS allowed origins for browser/web clients (comma-separated, or "*" for all)
CORS_ALLOWED_ORIGINS=*

# HTTP listen port
PORT=3000

# --- Web UI (admin dashboard at /ui) ---
# Password for the /ui login. Falls back to MEMORY_API_TOKEN if unset.
# If both UI_PASSWORD and MEMORY_API_TOKEN are empty, the UI is disabled (fail-closed).
UI_PASSWORD=
# Set to "true" ONLY for local http dev (omits the cookie Secure flag).
UI_COOKIE_INSECURE=false
