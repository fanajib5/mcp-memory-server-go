# PostgreSQL connection string.
# Local docker-compose: postgres://memory:memory_local_dev_password@db:5432/memory
# Coolify (existing Postgres service): postgres://<user>:<pass>@<internal-host>:5432/<db>
DATABASE_URL=postgres://memory:changeme@localhost:5432/memory

# Long random token — every MCP client must send this as: Authorization: Bearer <token>
# Generate one with: openssl rand -hex 32
MEMORY_API_TOKEN=changeme

PORT=3000
