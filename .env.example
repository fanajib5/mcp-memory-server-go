# PostgreSQL connection string
DATABASE_URL=postgres://user:pass@postgres:5432/memory?sslmode=require

# Static OAuth credentials (dapat dihasilkan dengan openssl rand -hex 32)
OAUTH_CLIENT_ID=my-client-id
OAUTH_CLIENT_SECRET=my-client-secret

# JWT signing secret (default fallback: MEMORY_API_TOKEN)
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32

# Public URL of this server (untuk OAuth issuer metadata), tanpa trailing slash
PUBLIC_URL=https://memory.example.com

# CORS allowed origins for browser/web clients (comma-separated, or "*" for all)
CORS_ALLOWED_ORIGINS=*

# HTTP listen port
PORT=3000

# --- Web UI (admin dashboard at /ui) ---
# Password for the /ui login. Falls back to MEMORY_API_TOKEN if unset.
# If both UI_PASSWORD and MEMORY_API_TOKEN are empty, the UI is disabled (fail-closed).
UI_PASSWORD=
# Set to "true" ONLY for local http dev (omits the cookie Secure flag).
UI_COOKIE_INSECURE=false

# --- Semantic Search (Phase 2: pgvector + Ollama) ---
# Ollama base URL. Leave empty to disable semantic search (lexical-only).
# In docker-compose: http://ollama:11434
OLLAMA_URL=http://ollama:11434
# Embedding model name (must be pulled in Ollama first: ollama pull bge-m3)
OLLAMA_EMBED_MODEL=bge-m3

# --- Auto-Backup ---
# Cron schedule (6-field robfig/cron or @daily/@hourly etc). Empty = disabled.
BACKUP_CRON=@daily
# Directory for backup files (Coolify can sync this volume to cloud).
BACKUP_DIR=/data/backups
# Number of backup files to keep (oldest deleted beyond this).
BACKUP_RETENTION=7
# Run a backup once on server startup (useful after deploys).
BACKUP_ON_START=false

# --- LLM Chat (Memory Chat UI at /ui/chat) ---
# Kilo Gateway API key. Leave empty to disable the LLM chat feature.
# Get your key at https://kilo.ai/gateway
KILO_GATEWAY_API_KEY=
# Kilo Gateway base URL (default: https://gateway.kilo.ai).
# Can also point to any OpenAI-compatible endpoint (e.g. Ollama http://host:11434).
KILO_GATEWAY_BASE_URL=https://gateway.kilo.ai
# Default model for chat (default: claude-sonnet-4-20250514).
KILO_GATEWAY_DEFAULT_MODEL=claude-sonnet-4-20250514
